{
  "telemetry": { "diagnostics": false, "metrics": false },
  "file_scan_exclusions": ["**/__pycache__", "**/.pytest_cache", "**/.git"],
  // --- ui ---
  "theme": {
    "mode": "system",
    "light": "Catppuccin Frappé - No Italics",
    "dark": "Catppuccin Frappé - No Italics",
  },
  "buffer_font_size": 20.8,
  "ui_font_size": 18,
  "agent_buffer_font_size": 19,
  "buffer_line_height": { "custom": 1 },
  "gutter": {
    "line_numbers": false,
    "runnables": false,
    "breakpoints": false,
    "folds": false,
    "bookmarks": false,
  },
  "tab_bar": {
    "show": false,
    "show_tab_bar_buttons": false,
    "show_nav_history_buttons": false,
  },
  "toolbar": { "breadcrumbs": true, "quick_actions": false },
  "status_bar": { "experimental.show": false },
  "project_panel": {
    "dock": "left",
    "bold_folder_labels": true,
    "indent_size": 10,
    "entry_spacing": "standard",
    "default_width": 200,
  },
  "git_panel": { "dock": "left", "default_width": 200 },
  "outline_panel": { "button": false },
  "collaboration_panel": { "button": false },
  "terminal": { "default_height": 750 },
  "unstable.ui_density": "compact",
  // --- ai ---
  "context_servers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
    },
  },
  "agent": {
    "dock": "right",
    "default_width": 300,
    "tool_permissions": { "default": "allow" },
    "default_profile": "write",
    "default_model": { "provider": "mistral", "model": "codestral-latest" },
  },
  "edit_predictions": { "mode": "subtle", "provider": "zed" },
  // --- qa ---
  "autosave": "on_focus_change",
  "languages": {
    "Python": {
      "format_on_save": "on",
      "language_servers": ["ruff", "ty"],
      "formatter": [
        { "language_server": { "name": "ruff" } },
        { "code_action": "source.organizeImports.ruff" },
        { "code_action": "source.fixAll.ruff" },
      ],
    },
  },
}
